# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Python virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging outputs
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Installer/build artifacts
*.exe
*.msi
*.deb
*.rpm
*.dmg
*.pkg

# Test, coverage, and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Logs and local runtime files
*.log
*.tmp
*.temp

# IDE/editor settings
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# OS-generated files
.DS_Store
Thumbs.db
Desktop.ini
